# ===== Python =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg
.ipynb_checkpoints/

# Virtual environments
venv/
.venv/
env/
ENV/

# ===== Data outputs (don't track large/regeneratable files) =====
# HDF5 outputs from tau pipelines, lightcone data, etc.
*.hdf5
*.h5

# Tiled/split outputs like tau_CMB.{ix}.{iy}.hdf5
tau_CMB.*.hdf5
tau_edges*.hdf5
*.npy
*.npz

# Plots/figures generated by scripts (keep code, not output images)
*.png
*.pdf
*.eps
# If you DO want to track specific final figures, un-ignore them explicitly, e.g.:
# !figures/fig6_final.png

# ===== SLURM / cluster job artifacts =====
slurm-*.out
slurm-*.err
*.out
*.err
*.log
core.*

# Job scratch/working directories
scratch/
tmp/
logs/

# ===== Editor / OS junk =====
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ===== Jupyter =====
*.ipynb_meta

# ===== Environment / secrets =====
.env
*.pem
*.key

# ===== Large input data (if symlinked or copied locally) =====
# Uncomment if your lightcone files (e.g. All_40.hdf5) live inside the repo dir
# All_*.hdf5
Lya-env/
Lya-env/
